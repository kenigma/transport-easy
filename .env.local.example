# TfNSW Open Data API key (server-only — never sent to browser)
# Register at https://opendata.transport.nsw.gov.au/
# Subscribe to: Trip Planner APIs and GTFS Realtime
TFNSW_API_KEY=your_tfnsw_api_key_here

# Google Maps API key (server-only — used for Geocoding and Distance Matrix APIs)
# https://console.cloud.google.com/ → Enable: Geocoding API, Distance Matrix API
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Google Maps API key (public — used by Maps JavaScript API in the browser)
# Can be the same key as above. Restrict to your domain in Google Cloud Console.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
